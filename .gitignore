# Dependencias y build
node_modules/
dist/

# Variables de entorno locales (contienen claves)
.env.local
.env.*.local
# La guía técnica usa este fichero para subir los secretos a Supabase de una vez.
# OJO: la regla .env* de más abajo NO lo cubre, porque empieza por ".secrets".
.secrets.env

# Supabase CLI
supabase/.temp/
supabase/.branches/

# Documentación de trabajo local (notas, prompts, specs): nunca entra en git
/docs/

# Datos maestros del Excel ARA: llevan teléfonos, emails y NIF de personas reales
/scripts/data/

# Sistema / editor
.DS_Store
*.log
.vercel
.env*
# ...salvo la plantilla de variables, que sí se versiona
!.env.local.example
