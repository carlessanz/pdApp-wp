# Copia este archivo a .env.local y rellena los valores.
# .env.local está en .gitignore: nunca se sube al repositorio.

# Dashboard de Supabase -> Settings -> API Keys.
# Usar la NUEVA publishable key (sb_publishable_...), NO la anon key obsoleta.
VITE_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# La MISMA cadena que el secreto WHATSAPP_SEND_API_KEY de las Edge Functions.
# Generar con: openssl rand -hex 24
VITE_WA_SEND_API_KEY=
